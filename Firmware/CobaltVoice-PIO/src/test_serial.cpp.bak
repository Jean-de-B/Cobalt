/**
 * TEST MINIMAL - Serial USB CDC
 * Renommez main.cpp en main.cpp.bak et ce fichier en main.cpp pour tester
 */

#include <Arduino.h>

// LED pins (XIAO nRF52840)
#define PIN_LED_RED   LED_RED
#define PIN_LED_GREEN LED_GREEN
#define PIN_LED_BLUE  LED_BLUE

void setup() {
    // LEDs
    pinMode(PIN_LED_RED, OUTPUT);
    pinMode(PIN_LED_GREEN, OUTPUT);
    pinMode(PIN_LED_BLUE, OUTPUT);

    // Allume rouge = démarrage
    digitalWrite(PIN_LED_RED, LOW);
    digitalWrite(PIN_LED_GREEN, HIGH);
    digitalWrite(PIN_LED_BLUE, HIGH);

    // Serial
    Serial.begin(115200);

    // Attend connexion (max 5s)
    uint32_t start = millis();
    while (!Serial && millis() - start < 5000) {
        delay(100);
        // Clignote bleu pendant attente
        digitalWrite(PIN_LED_BLUE, !digitalRead(PIN_LED_BLUE));
    }

    // Vert = prêt
    digitalWrite(PIN_LED_RED, HIGH);
    digitalWrite(PIN_LED_GREEN, LOW);
    digitalWrite(PIN_LED_BLUE, HIGH);

    Serial.println();
    Serial.println("=== TEST SERIAL XIAO nRF52840 ===");
    Serial.println("Si vous voyez ce message, Serial fonctionne!");
    Serial.println("Tapez quelque chose...");
    Serial.flush();
}

void loop() {
    static uint32_t lastPrint = 0;
    static uint32_t counter = 0;

    // Message toutes les 2 secondes
    if (millis() - lastPrint >= 2000) {
        lastPrint = millis();
        counter++;
        Serial.printf("[%lu] Heartbeat #%lu\n", millis(), counter);
        Serial.flush();

        // Toggle LED verte
        digitalWrite(PIN_LED_GREEN, !digitalRead(PIN_LED_GREEN));
    }

    // Echo des caractères reçus
    while (Serial.available()) {
        char c = Serial.read();
        Serial.printf("Recu: '%c' (0x%02X)\n", c, c);
        Serial.flush();

        // Flash bleu quand on reçoit
        digitalWrite(PIN_LED_BLUE, LOW);
        delay(50);
        digitalWrite(PIN_LED_BLUE, HIGH);
    }

    delay(10);
}
